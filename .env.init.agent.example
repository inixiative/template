# Agent Init - Environment Variables Example
# Copy this file to .env.init and fill in your values
# Then run: bun run init:agent

# ============================================
# Project Configuration
# ============================================
PROJECT_NAME=my-awesome-app
ORGANIZATION_NAME=Acme Corporation

# ============================================
# Infisical (Secrets Management)
# ============================================
# Get this from: https://app.infisical.com/organization/settings
INFISICAL_ORG_ID=

# ============================================
# PlanetScale (Database)
# ============================================
# Organization name (slug from PlanetScale dashboard)
PLANETSCALE_ORG=

# Region: us-east, us-west, eu-west, ap-south, ap-southeast, ap-northeast
PLANETSCALE_REGION=us-east

# Optional: Service token credentials (if not provided, will need manual input)
# Get from: https://app.planetscale.com/{org}/settings/service-tokens
PLANETSCALE_TOKEN_ID=
PLANETSCALE_TOKEN=

# ============================================
# Railway (Hosting)
# ============================================
# Get workspace ID from: railway whoami --json
RAILWAY_WORKSPACE_ID=

# Optional: API token (if not provided, will need manual input)
# Get from: https://railway.app/account/tokens
RAILWAY_API_TOKEN=

# ============================================
# Notes
# ============================================
# - All fields are required except those marked "Optional"
# - Tokens/secrets are optional during init but required for full automation
# - If tokens are not provided, you'll be prompted during setup
# - This file should be added to .gitignore (never commit secrets!)
