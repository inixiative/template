NODE_ENV=development
ENVIRONMENT=local
PORT=8000
LOG_LEVEL=debug

API_URL=http://localhost:8000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template
REDIS_URL=redis://localhost:6379

BETTER_AUTH_SECRET=your_secret_here_generate_with_openssl_rand_base64_32

# Webhooks (Ed25519 keypair for signing outbound webhooks)
# Generate with: openssl genpkey -algorithm Ed25519 -out private.pem && openssl pkey -in private.pem -pubout -out public.pem
WEBHOOK_SIGNING_PRIVATE_KEY=your_private_key_here
WEBHOOK_SIGNING_PUBLIC_KEY=your_public_key_here

# ─────────────────────────────────────────
# Optional integrations
# ─────────────────────────────────────────

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# BullBoard (required for non-local)
BULL_BOARD_USERNAME=
BULL_BOARD_PASSWORD=

# Sentry
SENTRY_ENABLED=false
SENTRY_DSN=

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=template-api

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CLOUDFRONT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Jobs overflow buffer (optional — these are the in-code defaults; tune per deploy)
# Durable backpressure in front of BullMQ. See tickets/INFRA-021-jobs-overflow-buffer.md.
JOBS_MAX_QUEUE_DEPTH=10000
JOBS_OUTBOX_FLUSH_MAX_ROWS=1000
JOBS_OUTBOX_FLUSH_LINGER_MS=200
JOBS_OVERFLOW_STUCK_MS=300000
JOBS_OVERFLOW_TTL_MS=60000
