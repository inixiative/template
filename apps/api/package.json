{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "local": "bun --hot --no-clear-screen src/index.ts",
    "local:worker": "bun --hot --no-clear-screen src/jobs/worker.ts",
    "start": "bun run src/index.ts",
    "start:worker": "bun run src/jobs/worker.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "test": "bun run --cwd ../.. with test api bun test --max-concurrency=1 --cwd apps/api src/",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "OPENAPI_OUTPUT_PATH=./openapi.local.gen.json bun run ./scripts/generate-openapi-spec.ts && cp ./openapi.local.gen.json ../../packages/ui/openapi.gen.json"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/hono": "^6.20.3",
    "@hono/zod-openapi": "^1.2.2",
    "@inixiative/json-rules": "^1.2.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/instrumentation": "^7.4.2",
    "@sentry/bun": "^10.42.0",
    "@template/db": "workspace:*",
    "@template/permissions": "workspace:*",
    "@template/shared": "workspace:*",
    "better-auth": "^1.5.4",
    "bullmq": "^5.70.4",
    "consola": "^3.4.2",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "lodash-es": "^4.17.23",
    "pluralize": "^8.0.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "@types/pluralize": "^0.0.33",
    "@types/stripe": "^8.0.417",
    "ioredis-mock": "^8.13.1",
    "typescript": "^5.9.3",
    "undici-types": "^7.24.3"
  }
}
