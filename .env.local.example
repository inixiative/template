# ========================================
# Root Environment Configuration
# ========================================
# Shared vars that apply to multiple apps.
# Each app also has its own .env.local.example.
# ========================================

NODE_ENV=development
ENVIRONMENT=local

# Project Identity
PROJECT_NAME=template
VITE_PROJECT_NAME=template

# URLs (used by API)
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
SUPERADMIN_URL=http://localhost:3002

# Auth
BETTER_AUTH_BASE_URL=http://localhost:8000

# Storage (S3-compatible — MinIO via docker compose locally, Railway Buckets in cloud)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_BUCKET_SYSTEM=template-system
STORAGE_BUCKET_USER=template-user
