{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@template/sdk": ["./src/index.ts"],
      "@template/sdk/openapi.gen.json": ["./openapi.gen.json"],
      "@template/sdk/lenses": ["./lenses/index.ts"],
      "@template/sdk/lenses/*": ["./lenses/*"],
      "@template/sdk/*": ["./src/*"]
    }
  },
  "include": ["src", "lenses"],
  "exclude": ["node_modules", "dist"]
}
