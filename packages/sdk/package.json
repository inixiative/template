{
  "name": "@template/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi.gen.json": "./openapi.gen.json",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate:sdk": "OPENAPI_SPEC_PATH=./openapi.gen.json openapi-ts -f openapiTs.config.ts && bun scripts/ensureSdkIndex.ts"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.0",
    "@tanstack/react-query": "^5.90.21",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  }
}
