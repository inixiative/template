{
  "name": "@template/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./generated/client/client": "./src/generated/client/client.ts",
    "./generated/client/models": "./src/generated/client/models.ts",
    "./generated/client/enums": "./src/generated/client/enums.ts",
    "./generated/zod/scalarSchemas.gen": "./src/generated/zod/scalarSchemas.gen.ts",
    "./lib/encryption/*": "./src/lib/encryption/*",
    "./test": "./src/test/index.ts",
    "./test/*": "./src/test/*",
    "./zod": "./src/generated/zod/schemas/index.ts",
    "./zod/models": "./src/generated/zod/schemas/variants/pure/index.ts",
    "./zod/*": "./src/generated/zod/schemas/*.ts",
    "./prisma/seed": "./prisma/seed.ts",
    "./prisma/seeds": "./prisma/seeds/index.ts"
  },
  "scripts": {
    "test": "bun run --cwd ../.. with test api bun test --max-concurrency=1 src/test/",
    "db:generate": "PRISMA_HIDE_UPDATE_MESSAGE=1 CHECKPOINT_DISABLE=1 prisma generate > /dev/null 2>&1 && bun run scripts/generateScalarSchemas.ts && bun run scripts/generatePrismaMap.ts && echo $(date) > .prisma.gen",
    "db:push": "prisma db push",
    "db:push:force": "[ \"$ENV\" = 'test' ] || [ \"$ENV\" = 'local' ] && prisma db push --accept-data-loss || echo 'ERROR: db:push:force only allowed in test/local env'",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "db:truncate:webhooks": "bun run prisma/truncateWebhookSubscriptions.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@supercharge/promise-pool": "^3.3.0",
    "@template/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.0",
    "ioredis-mock": "^8.13.1",
    "lodash-es": "^4.18.1",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@inixiative/prisma-map": "^0.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/lodash-es": "^4.17.12",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "prisma": "^7.4.2",
    "prisma-zod-generator": "^2.1.4",
    "zod": "^4.3.6"
  }
}
