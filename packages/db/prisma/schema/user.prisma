// ============================================================================
// USER
// ============================================================================

model User {
  id        String    @id @default(dbgenerated("uuidv7()")) @db.VarChar(36)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  email         String  @unique
  emailVerified Boolean @default(false)
  name          String?
  displayName   String?
  image         String?

  // Stamped on sign-in by the lastLoginAt hook (off Session create). Operational, not
  // versioned — see registries/ignoreFields.
  lastLoginAt DateTime?

  // Platform-level role (for superadmin access)
  platformRole PlatformRole @default(user)

  // Relations
  accounts               Account[]
  sessions               Session[]
  organizationUsers      OrganizationUser[]
  spaceUsers             SpaceUser[]
  tokens                 Token[]
  cronJobsCreated        CronJob[]
  webhookSubscriptions   WebhookSubscription[]
  contacts               Contact[]
  tagAttachments         TagAttachment[]
  tags                   Tag[]
  tagCategories          TagCategory[]
  inquiriesSent          Inquiry[]             @relation("InquirySource")
  inquiriesReceived      Inquiry[]             @relation("InquiryTarget")
  providerRefs           CustomerRef[]         @relation("providerRefs")
  auditLogsAsActor       AuditLog[]            @relation("AuditLogActorUser")
  auditLogsAsSpoofActor  AuditLog[]            @relation("AuditLogActorSpoofUser")
  auditLogsAsSubject     AuditLog[]            @relation("AuditLogSubjectUser")
  auditLogsAsContextUser AuditLog[]            @relation("AuditLogContextUser")
  communicationsSent     CommunicationLog[]    @relation("CommunicationSenderUser")
  communicationsReceived CommunicationLog[]    @relation("CommunicationRecipientUser")

  // ==========================================================================
  // TEMPLATE ABOVE — Add app-specific fields, relations, indexes below
  // ==========================================================================

  emailTemplates  EmailTemplate[]
  emailComponents EmailComponent[]

  ownedFiles       File[]            @relation("FileOwnerUser")
  ownedFolders     Folder[]          @relation("FolderOwnerUser")
  fileGrants       FilePermission[]  @relation("FilePermissionGranteeUser")
  resourceBindings ResourceBinding[] @relation("ResourceBindingUser")
}

enum PlatformRole {
  user
  superadmin
}

enum Role {
  owner
  admin
  member
  viewer
}
