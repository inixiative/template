// ============================================================================
// CONTACT - Unified contact-info entries (phone, email, social handles, …)
// ============================================================================
// Owner is false-polymorphic: User | Organization | Space (one FK populated to
// match `ownerModel`, enforced by the falsePolymorphism hook + registry entry).
// `value` is JSON whose shape varies by `type`; validation lives in the
// shared/contact/registry. `valueKey` is the canonical projection of `value`
// used for indexing and uniqueness (e.g. E.164 for phones, jid for whatsapp,
// `${classifier}:${handle}` for handle types).
//
// Per-owner uniqueness on valueKey is enforced by the composite @@unique below.
// All types use per-owner uniqueness — global-within-type is intentionally
// omitted until handle ownership can be verified (OAuth / DNS proof). Without
// verification, first-claim global locking is an abuse vector and blocks
// legitimate co-owners (e.g. a founder's personal + their org sharing @acme).

model Contact {
  id        String    @id @default(dbgenerated("uuidv7()")) @db.VarChar(36)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Owner — false polymorphism, exactly one FK matches the discriminator.
  ownerModel     ContactOwnerModel
  userId         String?           @db.VarChar(36)
  organizationId String?           @db.VarChar(36)
  spaceId        String?           @db.VarChar(36)

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  communications CommunicationLog[]

  type    ContactType
  subtype String? // semantics depend on type — see shared/contact/registry

  label    String?
  position Int     @default(0)

  value    Json
  valueKey String?

  // Per-row override for the rebac action rules on this resource.
  // Shape: Record<Action, ActionRule>. Read by check() — row-level wins over
  // the static rebacSchema for any action present here. Null = schema-only.
  permissionRules Json?

  verifiedAt DateTime?
  source     String?

  // Bouncer reachability verdict, cached to skip re-verifying every send (distinct from verifiedAt = ownership).
  deliverability          DeliverabilityStatus?
  deliverabilityCheckedAt DateTime?

  // Communication-kind opt-ins for this specific contact channel.
  // Native postgres enum array — value integrity enforced by the DB. Default
  // [platform, activity] matches the kind-level policy: platform + activity
  // are opt-out (on by default); marketing is opt-in (must be explicitly
  // added). `system` kind bypasses this list entirely (always delivered).
  // See `apps/api/src/lib/messaging/canDeliver.ts`.
  acceptedKinds CommunicationKind[] @default([platform, activity])

  // Per-owner uniqueness on valueKey — one composite per populated FK (NOT a single
  // composite over all three, which NULLS-distinct would let duplicate). Non-partial:
  // NULLS DISTINCT already leaves the null-FK branch unconstrained, and a plain unique is
  // a valid ON CONFLICT target so `upsert` works. Each doubles as that owner's lookup index.
  @@unique([userId, type, valueKey])
  @@unique([organizationId, type, valueKey])
  @@unique([spaceId, type, valueKey])
  @@index([userId, type, position])
  @@index([organizationId, type, position])
  @@index([spaceId, type, position])
  @@index([ownerModel])
  @@index([type, valueKey])
}

enum ContactOwnerModel {
  User
  Organization
  Space
}

enum DeliverabilityStatus {
  deliverable
  undeliverable
  risky
  unknown
}

enum ContactType {
  phone
  email
  website
  linkedin
  twitter
  github
  whatsapp
  telegram
  discord
  instagram
  facebook
  youtube
  tiktok
  bluesky
  threads
  reddit
  signal
  mastodon
  line
  wechat
  viber
  skype
}
