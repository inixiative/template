// ============================================================================
// TAG - Normalized label with optional category + intended-use resources
// ============================================================================
// `Tag.resources` is the intended-use layer (TagResource enum lives in
// tagAttachment.prisma since it also discriminates TagAttachment.ownerModel).
// PascalCase entries in TagResource are physical attachment models (User,
// Organization, …); camelCase entries are use-case concepts (userMessages, …).
// Empty resources array = unrestricted.

model Tag {
    id          String    @id @default(dbgenerated("uuidv7()")) @db.VarChar(36)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime?

    name        String                       // "founders", "us", "jobs"
    description String?
    resources   TagResource[]                // mix of PascalCase model names + camelCase use-cases. Empty = unrestricted.

    // Owner — false polymorphism. `platform` (default) means no specific
    // owner row → visible to everyone. PascalCase values pair to one FK
    // column. Polymorphism config in registries/falsePolymorphism.ts.
    ownerModel     TagResource @default(platform)
    userId         String?     @db.VarChar(36)
    organizationId String?     @db.VarChar(36)
    spaceId        String?     @db.VarChar(36)

    user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
    organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)

    tagCategoryId String?     @db.VarChar(36)
    tagCategory   TagCategory? @relation(fields: [tagCategoryId], references: [id], onDelete: SetNull)

    attachments TagAttachment[]

    @@unique([tagCategoryId, name])           // (category, name) unique; same name in different categories is fine
    @@index([tagCategoryId])
    @@index([ownerModel])
    @@index([userId])
    @@index([organizationId])
    @@index([spaceId])
}
