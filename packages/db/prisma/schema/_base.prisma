generator client {
  provider = "prisma-client"
  output   = "../../src/generated/client"
}

generator zod {
  provider             = "prisma-zod-generator"
  output               = "../../src/generated/zod"
  showModelDescription = false
  zodImportTarget      = "v4"
}

datasource db {
  provider = "postgresql"
}

