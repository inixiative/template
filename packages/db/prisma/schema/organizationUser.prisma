// ============================================================================
// ORGANIZATION USER - Join table for org membership
// ============================================================================

model OrganizationUser {
  id        String    @id @default(dbgenerated("uuidv7()")) @db.VarChar(36)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role         Role  @default(member)
  entitlements Json?

  // Relations
  organizationId     String       @db.VarChar(36)
  userId             String       @db.VarChar(36)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceUsers         SpaceUser[]
  tokens             Token[]
  auditLogsAsSubject AuditLog[]   @relation("AuditLogSubjectOrganizationUser")

  // ==========================================================================
  // TEMPLATE ABOVE — Add app-specific fields, relations, indexes below
  // ==========================================================================

  @@unique([organizationId, userId])
  @@index([userId])
}
