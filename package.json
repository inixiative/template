{
  "name": "template",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": "1.3.10"
  },
  "scripts": {
    "postinstall": "bash ./scripts/postinstall.sh",
    "init": "NODE_ENV=development bun --env-file=.env.init init/index.tsx",
    "init:agent": "NODE_ENV=development bun --env-file=.env.init init/agent.ts",
    "setup": "./scripts/setup/setup.sh",
    "sync-env": "./scripts/setup/sync-env.sh",
    "with": "./scripts/deployment/with-env.sh",
    "local": "./scripts/local.sh",
    "local:db": "docker-compose up -d --wait",
    "start:api": "bun --cwd apps/api start",
    "start:worker": "bun --cwd apps/api start:worker",
    "start:web": "bun --cwd apps/web preview",
    "start:db": "docker-compose up -d --wait",
    "stop:db": "docker-compose down",
    "reset:db": "docker-compose down && docker-compose up -d --wait && bun run db:push && bun run db:seed --prime",
    "build": "bun run '--filter=*' build",
    "pretest": "bun run with test api bun run --cwd packages/db db:push:force",
    "test": "bun run --cwd packages/permissions test && bun run --cwd packages/db test && bun run --cwd packages/email test && bun run --cwd apps/api test",
    "test:init": "bash init/tests/with-init-env.sh env NODE_ENV=test bun test init/",
    "test:fe": "bun run generate:sdk && bun run generate:routes && bun run --filter=@template/shared test && bun run --cwd packages/ui test && bun test --concurrency=1 tests/frontend",
    "typecheck": "bun run '--filter=*' typecheck",
    "typecheck:fe": "bun run generate:routes && bun run --cwd apps/web typecheck && bun run --cwd apps/admin typecheck && bun run --cwd apps/superadmin typecheck",
    "tsc": "bun run '--filter=*' typecheck",
    "db:generate": "bun run --filter=@template/db db:generate",
    "db:push": "bun run --filter=@template/db db:push",
    "db:push:force": "bun run --filter=@template/db db:push:force",
    "db:migrate": "bun run --filter=@template/db db:migrate",
    "db:deploy": "bun run --filter=@template/db db:deploy",
    "db:studio": "bun run --filter=@template/db db:studio",
    "db:seed": "bun run --filter=@template/db db:seed",
    "db:truncate:webhooks": "bun run with local api bun run --filter=@template/db db:truncate:webhooks",
    "db:dump": "./scripts/db/dump.sh",
    "db:restore": "./scripts/db/restore.sh",
    "db:clone": "./scripts/db/clone.sh",
    "generate:routes": "bun --cwd apps/web generate:routes && bun --cwd apps/admin generate:routes && bun --cwd apps/superadmin generate:routes",
    "generate:sdk": "bun run with local api bash ./scripts/generate-sdk.sh",
    "deploy": "./scripts/deployment/deploy.sh",
    "check": "bun run lint && bun run typecheck && bun run test && bun run test:fe && bash scripts/ci/run-ci-rules.sh",
    "lint": "biome check . && bun run lint:postBiome",
    "lint:postBiome": "./scripts/lint/run-post-biome-checks.sh",
    "lint:imports": "./scripts/lint/check-import-aliases.sh",
    "lint:generated": "./scripts/lint/check-generated-files.sh",
    "lint:fix": "biome check --write . && bun run lint:postBiome",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@lightpanda/browser": "^1.2.0",
    "@mendable/firecrawl-js": "^4.18.1",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/router-generator": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@types/bun": "^1.3.10",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "enhanced-resolve": "^5.20.0",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "resolutions": {
    "ioredis": "5.10.0"
  },
  "dependencies": {
    "@inixiative/json-rules": "^1.2.0",
    "autoprefixer": "^10.4.27",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lodash-es": "^4.17.23",
    "mermaid": "^11.12.3",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4"
  }
}
