# Test environment - copy to .env.test

ENVIRONMENT=test
NODE_ENV=test
LOG_LEVEL=error

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template_test
REDIS_URL=redis://noop:6379

API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
SUPERADMIN_URL=http://localhost:3002

BETTER_AUTH_SECRET=test-secret-32-characters-minimum!!
INTERNAL_SHARED_SECRET=test-internal-secret

